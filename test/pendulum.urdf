<?xml version="1.0"?>
<robot name="pendulum">
  <link name="base">
    <inertial>
      <mass value="0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
  </link>

  <link name="rod">
    <inertial>
      <origin xyz="0 0 -0.5"/>
      <mass value="1.0"/>
      <inertia ixx="0.083" ixy="0" ixz="0" iyy="0.083" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.5"/>
      <geometry><cylinder radius="0.02" length="1.0"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.5"/>
      <geometry><cylinder radius="0.02" length="1.0"/></geometry>
    </collision>
  </link>

  <joint name="joint0" type="revolute">
    <parent link="base"/>
    <child link="rod"/>
    <origin xyz="0 0 1.02"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="10"/>
  </joint>
</robot>
